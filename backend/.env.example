# Configuración de la base de datos PostgreSQL
# Copie este archivo a .env y rellene los valores
DB_USER=postgres
DB_HOST=localhost
DB_NAME=otorrinonet
DB_PASSWORD=your_database_password
DB_PORT=5432

# Claves de hCaptcha
# Obtenga estas claves de su dashboard de hCaptcha
HCAPTCHA_SITE_KEY=your_site_key_here
HCAPTCHA_SECRET_KEY=your_secret_key_here